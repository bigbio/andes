# Compiled source #
###################
*.com
*.class
*.dll
*.exe
*.o
*.so

# Packages #
############
# it's better to unpack these files and commit the raw source
# git has its own built in compression methods
*.7z
*.dmg
*.gz
*.iso
# *.jar   still have some libraries in the repo, un-comment when they are in own maven or something
*.rar
*.tar
*.zip

# Logs and databases #
######################
*.log*
*.sql
*.sqlite

# OS generated files #
######################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Intellij generated files #
#####################
*.iml

# Eclipse generated files #
###########################
/.settings
.classpath
.project

# Directory to ignore #
#####################
log/
logs/
target/
.idea/
.settings
.metadata

# Benchmark: keep only CI scaffold, ignore heavy local artifacts
benchmark/*
!benchmark/README.md
!benchmark/ci/
!benchmark/ci/**
benchmark/**/data/
benchmark/**/results/
benchmark/**/baseline/
benchmark/**/new/
benchmark/**/parser_only/
benchmark/**/*.mzML
benchmark/**/*.mzML.gz
benchmark/**/*.mzid
benchmark/**/*.fasta
benchmark/**/*.canno
benchmark/**/*.cnlcp
benchmark/**/*.csarr
benchmark/**/*.cseq
benchmark/**/*.revCat.*

# Generated suffix-array index files (large; reproducible)
*.revCat.canno
*.revCat.cnlcp
*.revCat.csarr
*.revCat.cseq
*.revCat.fasta

# Cursor / Codacy (local tooling)
.cursor/
.codacy/

# Directory to ignore #
#####################
log/
logs/
target/
.idea/
.settings
.metadata

# Python bytecode cache (benchmark helper scripts)
__pycache__/
*.pyc

# Benchmark: keep only CI scaffold, ignore heavy local artifacts.
# Parity scripts + fixtures are local-only context; not part of the tool code.
benchmark/*
!benchmark/README.md
!benchmark/ci/
!benchmark/capture-references.sh

# Parity-analysis docs (iter-by-iter notes + diff CSVs) are local-only
# development context, not part of the shipped repo.
docs/parity-analysis/*
!docs/parity-analysis/notes/
!docs/parity-analysis/notes/2026-05-25-precursor-cal-ship-gates.md
!docs/parity-analysis/notes/2026-05-25-spece-tail-exploration.md
!docs/parity-analysis/notes/2026-05-28-phase2-peak-rank-parity.md
!docs/parity-analysis/notes/2026-05-26-score-psm-trace-findings.md
!docs/parity-analysis/notes/score-psm-trace-artifacts/
!docs/parity-analysis/notes/score-psm-trace-artifacts/*
!docs/parity-analysis/snapshots/
!docs/parity-analysis/snapshots/cal-shifts-2026-05-25.json

# Java reference outputs from `mvn -Pcapture-references` — large; not committed.
references/

# Generated suffix-array index files (large; reproducible)
*.revCat.canno
*.revCat.cnlcp
*.revCat.csarr
*.revCat.cseq
*.revCat.fasta

# Cursor / Codacy (local tooling)
.cursor/
.codacy/

.claude/investigations/msgfplus_research_report.md


